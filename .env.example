# Lobuddy Configuration
# Copy this file to .env and fill in your actual values

# LLM Configuration (OpenAI compatible)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Sub-Agent Configuration (multimodal / image analysis)
# 子Agent模型配置。若需要图片分析能力，此值为必填；为空则图片分析不可用
LLM_MULTIMODAL_MODEL=qwen-vl-max
# Optional: 子Agent专用 API 端点（不填则回退到 LLM_BASE_URL）
# LLM_MULTIMODAL_BASE_URL=https://api.openai.com/v1
# Optional: 子Agent专用 API 密钥（不填则回退到 LLM_API_KEY）
# LLM_MULTIMODAL_API_KEY=your_multimodal_api_key
# Nanobot Configuration
# NANOBOT_CONFIG_PATH=~/.nanobot/config.json
# WORKSPACE_PATH=./workspace
# NANOBOT_MAX_ITERATIONS=40
# TASK_TIMEOUT=120

# Application Configuration
# APP_NAME=Lobuddy
# DATA_DIR=./data
# LOGS_DIR=./logs
# LOG_LEVEL=INFO
# RESULT_POPUP_DURATION=5

# UI Configuration
# PET_NAME=Lobuddy

# =========================
# Lobuddy Companion Features
# =========================
# Pet Click Feedback
# PET_CLICK_FEEDBACK_ENABLED=true
# PET_CLICK_COOLDOWN_MS=350
# PET_CLICK_EASTER_EGG_COUNT=5
# PET_CLICK_MESSAGES=我在呢～|今天也辛苦啦！|摸摸头成功！|要不要休息一下？|我会陪着你的～
# PET_CLICK_EASTER_EGG_MESSAGE=别戳啦，会害羞的！
# PET_BUBBLE_DURATION_MS=2200
# Pet Clock
# PET_CLOCK_ENABLED=true
# PET_CLOCK_SHOW_SECONDS=false
# PET_CLOCK_REFRESH_MS=30000
# PET_CLOCK_HOVER_FULL_FORMAT=true
# Chat Message Time
# CHAT_MESSAGE_TIME_ENABLED=true
# CHAT_TIME_DIVIDER_ENABLED=true
# CHAT_TIME_DIVIDER_GAP_MINUTES=5
# CHAT_TIME_FORMAT=HH:mm
# CHAT_DATE_FORMAT=yyyy年M月d日 dddd
# Conversation Timeline
# CONVERSATION_TIMELINE_ENABLED=true
# CONVERSATION_TIMELINE_TOOLTIP_ENABLED=true
# CONVERSATION_TIMELINE_PREVIEW_MAX_CHARS=32
# CONVERSATION_TIMELINE_MIN_DOT_GAP_PX=8
# Pet State System
# PET_STATE_ENABLED=true
# PET_IDLE_AFTER_MINUTES=10
# PET_SLEEPY_START_HOUR=23
# PET_SLEEPY_END_HOUR=6
# PET_STATE_TEXT_IDLE=待机中
# PET_STATE_TEXT_LISTENING=倾听中
# PET_STATE_TEXT_THINKING=思考中
# PET_STATE_TEXT_WORKING=工作中
# PET_STATE_TEXT_HAPPY=开心
# PET_STATE_TEXT_SLEEPY=困困
# PET_STATE_TEXT_ERROR=需要看看
# Daily Greeting (default off)
# DAILY_GREETING_ENABLED=false
# DAILY_GREETING_MAX_PER_DAY=1
# GREETING_MORNING=早上好，今天也一起加油～
# GREETING_AFTERNOON=下午好，要不要喝口水？
# GREETING_EVENING=晚上好，今天辛苦啦。
# GREETING_NIGHT=已经很晚啦，注意休息哦。
# Focus Mode (reserved)
# FOCUS_MODE_ENABLED=false
# FOCUS_DEFAULT_MINUTES=25
# FOCUS_BREAK_MINUTES=5

# =========================
# Memory Profile (4.29.1)
# =========================
# MEMORY_PROFILE_ENABLED=true
# MEMORY_PROFILE_FILE=data/memory/USER.md
# MEMORY_PROFILE_INJECT_ENABLED=true
# MEMORY_PROFILE_MAX_INJECT_CHARS=2000
# MEMORY_PROFILE_UPDATE_EVERY_N_USER_MESSAGES=6
# MEMORY_PROFILE_UPDATE_ON_SESSION_END=true
# MEMORY_PROFILE_UPDATE_ON_STRONG_SIGNAL=true
# MEMORY_PROFILE_DAILY_CONSOLIDATION=false
# MEMORY_PROFILE_MAX_RECENT_MESSAGES=30
# MEMORY_PROFILE_MAX_PATCH_ITEMS=8
# MEMORY_PROFILE_REQUIRE_HIGH_CONFIDENCE=true
# MEMORY_PROFILE_MIN_CONFIDENCE=0.75
# MEMORY_PROFILE_SHOW_UPDATE_NOTICE=true

# =========================
# Focus Mode (4.29.1)
# =========================
# FOCUS_MODE_ENABLED=false
# FOCUS_DEFAULT_MINUTES=25
# FOCUS_BREAK_MINUTES=5
# FOCUS_END_REMINDER_ENABLED=true
# FOCUS_BREAK_END_REMINDER_ENABLED=true
# FOCUS_MUTE_GREETING=true
# FOCUS_STATUS_TEXT=Focusing
# FOCUS_AUTO_LOOP=false

# =========================
# Skill Panel (4.29.1)
# =========================
# SKILL_PANEL_ENABLED=true
# SKILL_PANEL_SHOW_EXAMPLES=true
# SKILL_PANEL_CLICK_TO_FILL_INPUT=true
# SKILL_PANEL_SHOW_PERMISSION_BADGE=true

# =========================
# Theme System (4.30)
# =========================
# THEME_PRESET=cozy_orange
# THEME_PRIMARY_COLOR=
# THEME_BACKGROUND_COLOR=
# THEME_ACCENT_COLOR=
# USER_THEMES_MAX_COUNT=20
# ACTIVE_USER_THEME_ID=

# Message Highlight (reserved)
# MESSAGE_HIGHLIGHT_ENABLED=false
# Memory Card (reserved)
# MEMORY_CARD_ENABLED=false

# =========================
# Memory System V2 (5.2)
# =========================
# MEMORY_USE_FTS5=true
# MEMORY_PROMPT_BUDGET_CHARS=4000
# MEMORY_PROMPT_BUDGET_PERCENT=0.20
# MEMORY_SYSTEM_PROFILE_FILE=data/memory/SYSTEM.md
# MEMORY_PROJECT_PROFILE_FILE=data/memory/PROJECT.md
# MEMORY_MAX_EPISODIC_RESULTS=5
# MEMORY_SUMMARY_TRIGGER_TURNS=10
# MEMORY_SUMMARY_MAX_CHARS=2000
# MEMORY_ENABLE_MIGRATION=true

# =========================
# Skill System V2 (5.2)
# =========================
# SKILL_AUTO_CANDIDATE_ENABLED=false
# SKILL_CANDIDATE_MIN_TOOLS_USED=2
# SKILL_CANDIDATE_AUTO_APPROVE_THRESHOLD=0.9
# SKILL_MAINTENANCE_INTERVAL_HOURS=24
# SKILL_STALE_DISABLE_DAYS=90
# SKILL_STALE_REVIEW_DAYS=60
# SKILL_MAX_FILE_LINES=500
# SKILL_FAILURE_RATE_THRESHOLD=0.40
# SKILL_FAILURE_RATE_MIN_USES=5
# SKILL_ARCHIVE_DIR=data/skills/archive

# =========================
# Memory System 5.3 (统一记忆网关)
# =========================
# Memory session_search tool — searches chat history for cold recall
# MEMORY_SESSION_SEARCH_ENABLED=false
# MEMORY_SESSION_SEARCH_DEFAULT_SCOPE=current_session
# MEMORY_SESSION_SEARCH_MAX_RESULT_CHARS=300
# MEMORY_SESSION_SEARCH_TOTAL_BUDGET_CHARS=1500
# Memory write gateway
# MEMORY_GATEWAY_MIN_CONFIDENCE=0.75
# MEMORY_GATEWAY_MAX_ITEMS_PER_PATCH=8
# Memory hot context (frozen bundle token budgets)
# MEMORY_HOT_USER_PROFILE_TOKENS=500
# MEMORY_HOT_SYSTEM_PROFILE_TOKENS=300
# MEMORY_HOT_PROJECT_CONTEXT_TOKENS=800
# Memory lint service
# MEMORY_LINT_DUPLICATE_SIMILARITY=0.8
# MEMORY_LINT_STALE_DAYS=90
# MEMORY_LINT_LOW_CONFIDENCE_DAYS=30
# MEMORY_LINT_ENABLED=true
# Dream command blocking (5.3)
# MEMORY_BLOCK_DREAM_COMMANDS=true

# =========================
# Execution Governance 5.4
# =========================
# 执行治理：阻止 agent 在"打开桌面应用"时递归搜索 Program Files/AppData
# EXECUTION_GOVERNANCE_ENABLED=true
# EXECUTION_LOCAL_TOOLS_ENABLED=true
# EXECUTION_MAX_TOOL_CALLS_PER_TASK=6
# EXECUTION_MAX_LOCAL_LOOKUP_CALLS=2
# EXECUTION_MAX_SHELL_CALLS_PER_TASK=2
# EXECUTION_BLOCK_SHELL_FOR_LOCAL_OPEN=true
# EXECUTION_MAX_TOOL_RESULT_CHARS=3000
# EXECUTION_TRACE_ENABLED=true
