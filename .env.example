# Lobuddy Configuration
# Copy this file to .env and fill in your actual values

# LLM Configuration (OpenAI compatible)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Sub-Agent Configuration (multimodal / image analysis)
# 子Agent模型配置。若需要图片分析能力，此值为必填；为空则图片分析不可用
LLM_MULTIMODAL_MODEL=qwen-vl-max
# Optional: 子Agent专用 API 端点（不填则回退到 LLM_BASE_URL）
# LLM_MULTIMODAL_BASE_URL=https://api.openai.com/v1
# Optional: 子Agent专用 API 密钥（不填则回退到 LLM_API_KEY）
# LLM_MULTIMODAL_API_KEY=your_multimodal_api_key
# Nanobot Configuration
# NANOBOT_CONFIG_PATH=~/.nanobot/config.json
# WORKSPACE_PATH=./workspace
# NANOBOT_MAX_ITERATIONS=40
# TASK_TIMEOUT=120

# Application Configuration
# APP_NAME=Lobuddy
# DATA_DIR=./data
# LOGS_DIR=./logs
# LOG_LEVEL=INFO
# RESULT_POPUP_DURATION=5

# UI Configuration
# PET_NAME=Lobuddy

# =========================
# Lobuddy Companion Features
# =========================
# Pet Click Feedback
# PET_CLICK_FEEDBACK_ENABLED=true
# PET_CLICK_COOLDOWN_MS=350
# PET_CLICK_EASTER_EGG_COUNT=5
# PET_CLICK_MESSAGES=我在呢～|今天也辛苦啦！|摸摸头成功！|要不要休息一下？|我会陪着你的～
# PET_CLICK_EASTER_EGG_MESSAGE=别戳啦，会害羞的！
# PET_BUBBLE_DURATION_MS=2200
# Pet Clock
# PET_CLOCK_ENABLED=true
# PET_CLOCK_SHOW_SECONDS=false
# PET_CLOCK_REFRESH_MS=30000
# PET_CLOCK_HOVER_FULL_FORMAT=true
# Chat Message Time
# CHAT_MESSAGE_TIME_ENABLED=true
# CHAT_TIME_DIVIDER_ENABLED=true
# CHAT_TIME_DIVIDER_GAP_MINUTES=5
# CHAT_TIME_FORMAT=HH:mm
# CHAT_DATE_FORMAT=yyyy年M月d日 dddd
# Conversation Timeline
# CONVERSATION_TIMELINE_ENABLED=true
# CONVERSATION_TIMELINE_TOOLTIP_ENABLED=true
# CONVERSATION_TIMELINE_PREVIEW_MAX_CHARS=32
# CONVERSATION_TIMELINE_MIN_DOT_GAP_PX=8
# Pet State System
# PET_STATE_ENABLED=true
# PET_IDLE_AFTER_MINUTES=10
# PET_SLEEPY_START_HOUR=23
# PET_SLEEPY_END_HOUR=6
# PET_STATE_TEXT_IDLE=待机中
# PET_STATE_TEXT_LISTENING=倾听中
# PET_STATE_TEXT_THINKING=思考中
# PET_STATE_TEXT_WORKING=工作中
# PET_STATE_TEXT_HAPPY=开心
# PET_STATE_TEXT_SLEEPY=困困
# PET_STATE_TEXT_ERROR=需要看看
# Daily Greeting (default off)
# DAILY_GREETING_ENABLED=false
# DAILY_GREETING_MAX_PER_DAY=1
# GREETING_MORNING=早上好，今天也一起加油～
# GREETING_AFTERNOON=下午好，要不要喝口水？
# GREETING_EVENING=晚上好，今天辛苦啦。
# GREETING_NIGHT=已经很晚啦，注意休息哦。
# Focus Mode (reserved)
# FOCUS_MODE_ENABLED=false
# FOCUS_DEFAULT_MINUTES=25
# FOCUS_BREAK_MINUTES=5
# Message Highlight (reserved)
# MESSAGE_HIGHLIGHT_ENABLED=false
# Memory Card (reserved)
# MEMORY_CARD_ENABLED=false
